# Anthropic API key (required for negotiation AI)
ANTHROPIC_API_KEY=your_key_here

# Reddit API credentials (optional — app works without these, falls back to cached/sample data)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=haggle-app/1.0

# Exchange rate API (optional — uses open.er-api.com if not set, no key needed)
# EXCHANGE_RATE_API_KEY=your_key_here
